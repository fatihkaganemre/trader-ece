# Supabase Environment Variables Template
# 
# VITE_SUPABASE_SETUP.md dosyasındaki "Step 6"ı takip edin
# Aşağıdaki değerleri Supabase Dashboard'dan kopyalayın

# 1. Settings > API > URL'i kopyala
VITE_SUPABASE_URL=https://your-project.supabase.co

# 2. Settings > API > anon public key'i kopyala
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
